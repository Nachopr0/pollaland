d version update checker\\n+ Updated water roots to use new model\\n+ Updated flowering oak to display flowers during felling animation\\n+ Renamed OakFloweringVine to OakIvyVines (as flowering vines were removed)\\n+ Updated textures slightly, making them more consistent\\nBug Fixes:\\n+ Fixed jungle twiglets in oasis not having their proper species\\n+ Fixed missing translation for certain species\",","\t\t\"1.12.2-1.4.4\": \"New Features:\\n-Mangrove world generation\\n-Improvements to mangrove and rooty water block model\"","\t},","\t\"promos\": {","\t\t\"1.12.2-latest\": \"1.12.2-1.5.1\",","\t\t\"1.12.2-recommended\": \"1.12.2-1.5.1\"","\t}","}"],"stylingDirectives":[[],[[1,11,"pl-ent"],[13,88,"pl-s"],[13,14,"pl-pds"],[87,88,"pl-pds"]],[[1,9,"pl-ent"]],[[2,16,"pl-ent"],[18,267,"pl-s"],[18,19,"pl-pds"],[32,34,"pl-cce"],[92,94,"pl-cce"],[107,109,"pl-cce"],[141,143,"pl-cce"],[153,155,"pl-cce"],[266,267,"pl-pds"]],[[2,16,"pl-ent"],[18,907,"pl-s"],[18,19,"pl-pds"],[32,34,"pl-cce"],[80,82,"pl-cce"],[130,132,"pl-cce"],[167,169,"pl-cce"],[217,219,"pl-cce"],[282,284,"pl-cce"],[360,362,"pl-cce"],[488,490,"pl-cce"],[503,505,"pl-cce"],[535,537,"pl-cce"],[575,577,"pl-cce"],[644,646,"pl-cce"],[721,723,"pl-cce"],[779,781,"pl-cce"],[791,793,"pl-cce"],[857,859,"pl-cce"],[906,907,"pl-pds"]],[[2,16,"pl-ent"],[18,116,"pl-s"],[18,19,"pl-pds"],[32,34,"pl-cce"],[60,62,"pl-cce"],[115,116,"pl-pds"]],[],[[1,9,"pl-ent"]],[[2,17,"pl-ent"],[19,33,"pl-s"],[19,20,"pl-pds"],[32,33,"pl-pds"]],[[2,22,"pl-ent"],[24,38,"pl-s"],[24,25,"pl-pds"],[37,38,"pl-pds"]],[],[]],"colorizedLines":null}},"title":"DynamicTrees-BOP/version_info.json at 1.12.2 · DynamicTreesTeam/DynamicTrees-BOP","appPayload":{},"meta":{"title":"DynamicTrees-BOP/version_info.json at 1.12.2 · DynamicTreesTeam/DynamicTrees-BOP"}}</script>
